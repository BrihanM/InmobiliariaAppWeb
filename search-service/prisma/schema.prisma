generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model properties {
  id                   String    @id @default(uuid())
  title                String
  description          String?
  price                Float
  property_type_id     String
  transaction_type_id  String
  status_id            String
  address_id           String
  created_at           DateTime  @default(now())
  updated_at           DateTime? @updatedAt
  deleted_at           DateTime?

  address              addresses @relation(fields: [address_id], references: [id])
  property_type        property_types @relation(fields: [property_type_id], references: [id])
  transaction_type     transaction_types @relation(fields: [transaction_type_id], references: [id])
  status               property_status @relation(fields: [status_id], references: [id])
  images               property_images[]

  @@index([price])
  @@index([property_type_id])
  @@index([transaction_type_id])
  @@index([status_id])
}

model addresses {
  id        String @id @default(uuid())
  street    String
  city      String
  state     String?
  country   String
  postal    String?

  properties properties[]
  @@index([city])
}

model property_types {
  id   String @id @default(uuid())
  name String
  properties properties[]
}

model transaction_types {
  id   String @id @default(uuid())
  name String
  properties properties[]
}

model property_status {
  id   String @id @default(uuid())
  name String
  properties properties[]
}

model property_images {
  id          String @id @default(uuid())
  property_id String
  url         String
  created_at  DateTime @default(now())

  property properties @relation(fields: [property_id], references: [id])
  @@index([property_id])
}
